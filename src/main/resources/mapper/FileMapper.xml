<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.lancit.domain.file.mapper.FileMapper">

    <!--아이디로 filedto 찾기 -->
    <select id="findById" resultType="FileDTO">
        SELECT * FROM file WHERE file_id = #{fileId}
    </select>

    <!-- parentId 기준 파일 목록 조회 -->
    <select id="findByParent" resultType="FileDTO">
        SELECT *
        FROM file
        WHERE parent_type = #{parentType}
          AND parent_id   = #{parentId}
    </select>

    <!--파일 dto 삽입하기-->
    <!--useGeneratedKeys : auto_increment를 다시 반환, keyProperty: 가져온 키를 어느 필드에 넣을지 지정-->
    <insert id="insert" useGeneratedKeys="true" keyProperty="fileId"> 
        INSERT INTO file (
            user_email,
            company_email,
            sys_name,
            ori_name,
            parent_type,
            parent_id,
            upload_path,
            created_at,
            file_size
        ) VALUES (
            #{userEmail},
            #{companyEmail},
            #{sysName},
            #{oriName},
            #{parentType},
            #{parentId},
            #{uploadPath},
            NOW(),
            #{fileSize}
        )
    </insert>

    <!-- 파일 dto 삭제하기 -->
    <delete id="delete">
        DELETE FROM file WHERE file_id = #{fileId}
    </delete>

	 <!-- OwnerCheckAspect 에서 소유자 검증 -->
	<select id="findOwnerEmailById" resultType="String">
	    SELECT COALESCE(user_email, company_email) FROM file
	    WHERE file_id = #{fileId}
	</select>

	<!-- 유저의 TEMP 파일 조회 (업로드 시 기존 TEMP 정리용) -->
	<select id="findTempByEmail" resultType="com.ssafy.lancit.domain.file.dto.FileDTO">
	    SELECT * FROM file
	    WHERE parent_type = 'TEMP'
	    AND (user_email = #{email} OR company_email = #{email})
	</select>

	<!-- parentType 변경 (TEMP → PROFILE) -->
	<update id="updateParentType">
	    UPDATE file
	    SET parent_type = #{parentType}
	    WHERE file_id = #{fileId}
	</update>
	
	
	<!-- 유저 소유 파일 전체 조회 (탈퇴 시 GCS 삭제용) -->
	<select id="findByUserEmail" resultType="com.ssafy.lancit.domain.file.dto.FileDTO">
	    SELECT * FROM file WHERE user_email = #{userEmail}
	</select>
	
	<!-- 회사 소유 파일 전체 조회 (탈퇴 시 GCS 삭제용) -->
	<select id="findByCompanyEmail" resultType="com.ssafy.lancit.domain.file.dto.FileDTO">
	    SELECT * FROM file WHERE company_email = #{companyEmail}
	</select>
	
</mapper>