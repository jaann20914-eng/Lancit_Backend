    <!-- 진행 중 계약 존재 여부 확인 (IN_PROGRESS / COMPLETED_PENDING) -->
	<select id="existsActiveContractByEmail" resultType="boolean">
	    SELECT COUNT(*) > 0
	    FROM contract
	    WHERE (freelancer_email = #{email} OR company_email = #{email})
	    AND status IN ('IN_PROGRESS', 'COMPLETED_PENDING')
	</select>

