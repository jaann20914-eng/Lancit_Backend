<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.lancit.domain.contract.mapper.ContractFileMapper">

<!--    <resultMap id="ContractFileResultMap" type="com.ssafy.lancit.domain.contract.dto.ContractFileDTO">
        <id     property="contractFileId" column="contract_file_id"/>
        <result property="contractId"     column="contract_id"/>
        <result property="fileId"         column="file_id"/>
        <result property="type"           column="type"
                typeHandler="org.apache.ibatis.type.EnumTypeHandler"/>
        <result property="createdAt"      column="created_at"/>
        <result property="uploaderEmail"  column="uploader_email"/>
    </resultMap>-->


    <!-- 파일 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="contractFileId">
        INSERT INTO contract_file (contract_id, file_id, type, uploader_email, created_at)
        VALUES (#{contractId}, #{fileId}, #{type}, #{uploaderEmail}, NOW())
    </insert>


    <!-- 계약의 전체 파일 조회 -->
    <select id="findByContractId" resultType="ContractFileDTO">
        SELECT *
        FROM contract_file
        WHERE contract_id = #{contractId}
        ORDER BY created_at DESC
    </select>


    <!-- 단건 조회 -->
    <select id="findById" resultType="ContractFileDTO">
        SELECT *
        FROM contract_file
        WHERE contract_file_id = #{contractFileId}
    </select>


    <!-- PDF 조회 -->
    <select id="findPdfByContractId" resultType="ContractFileDTO">
        SELECT *
        FROM contract_file
        WHERE contract_id = #{contractId}
          AND type = 'PDF'
        LIMIT 1
    </select>


    <!-- 컨펌파일 목록 조회 -->
    <select id="findConfirmFilesByContractId" resultType="ContractFileDTO">
        SELECT *
        FROM contract_file
        WHERE contract_id = #{contractId}
          AND type = 'CONFIRM'
        ORDER BY created_at DESC
    </select>


    <!-- 삭제 -->
    <delete id="delete">
        DELETE FROM contract_file
        WHERE contract_file_id = #{contractFileId}
    </delete>

</mapper>