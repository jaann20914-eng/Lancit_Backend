<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.lancit.domain.proposal.mapper.ProposalMapper">

    <!-- TODO 지원: 프리랜서가 받은 제안서 목록 조회
         - WHERE freelancer_email = #{email}
         - ORDER BY sent_at DESC -->
    <select id="findByFreelancer" resultType="com.ssafy.lancit.domain.proposal.dto.ProposalDTO">

    </select>

    <!-- TODO 지원: 회사가 보낸 제안서 목록 조회
         - WHERE company_email = #{email}
         - ORDER BY sent_at DESC -->
    <select id="findByCompany" resultType="com.ssafy.lancit.domain.proposal.dto.ProposalDTO">

    </select>

    <!-- TODO 지원: 제안서 단건 조회
         - WHERE proposal_id = #{proposalId} -->
    <select id="findById" resultType="com.ssafy.lancit.domain.proposal.dto.ProposalDTO">

    </select>

    <!-- TODO 지원: 제안서 삽입
         - useGeneratedKeys="true" keyProperty="proposalId" 유지할 것
         - sent_at = NOW() 로 처리 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="proposalId">

    </insert>

    <!-- TODO 지원: 제안서 상태 변경
         - UPDATE proposal SET status = #{status}
         - WHERE proposal_id = #{proposalId} -->
    <update id="updateStatus">

    </update>

</mapper>